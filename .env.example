# Copie este arquivo para ".env" e preencha com as credenciais do seu projeto Supabase.
# Sem essas variáveis o app roda em modo demo (sem persistência real) — ver src/lib/supabase.ts.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Opcional — habilita as camadas "Satélite"/"Híbrido" no mapa (/mapa) via MapTiler.
# Sem essa chave, essas duas opções aparecem desabilitadas no controle de camadas e o
# mapa continua funcionando normalmente com "Padrão"/"Escuro". Avalie licença/custo do
# provedor antes de configurar — ver src/features/gis/mapStyles.ts.
VITE_MAPTILER_KEY=
